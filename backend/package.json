{
  "name": "shortly",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh scripts/dev.sh",
    "dev:down": "docker compose -f compose.yaml -f compose.dev.yaml down --remove-orphans",
    "start": "bun run start:creation",
    "start:creation": "bun src/index.ts",
    "start:docker-stats": "bun src/docker-stats-exporter.ts",
    "start:redirect": "bun src/redirect-index.ts",
    "docker:start": "docker compose up --build --detach --wait",
    "load:clean": "docker compose --profile maintenance run --rm load-cleanup",
    "load:create": "docker compose --profile loadtest run --rm k6",
    "load:redirect": "docker compose --profile loadtest run --rm k6 run /scripts/redirect-short-urls.js",
    "test:gateway": "GATEWAY_BASE_URL=http://localhost:5000 bun test test/gateway.test.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3"
  }
}
